rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------
    // GLOBAL CATCH-ALL DEFAULT DENY (Zero Trust Gate)
    // ----------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ----------------------------------------------------
    // REUSABLE SECURITY DEFINITIONS & GLOBAL HELPERS
    // ----------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn();
    }

    function isCurrentUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Helper to fetch user status and role safely
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isApproved() {
      return isSignedIn() && (
        (request.auth.token.email != null && (request.auth.token.email == 'n.gujarati25288@gmail.com' || request.auth.token.email == '8511125288@daily-learning-exam.com')) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status in ['approved', 'Approved'] ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin']
        ))
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && (request.auth.token.email == 'n.gujarati25288@gmail.com' || request.auth.token.email == '8511125288@daily-learning-exam.com')) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
        ))
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && (request.auth.token.email == 'n.gujarati25288@gmail.com' || request.auth.token.email == '8511125288@daily-learning-exam.com')) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin')
      );
    }

    // ----------------------------------------------------
    // VALIDATION BLUEPRINTS
    // ----------------------------------------------------
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.mobile is string && data.mobile.size() <= 20 &&
             data.role is string && data.role in ['student', 'admin', 'super_admin'] &&
             data.status is string && data.status in ['pending', 'approved', 'blocked', 'Approved'];
    }

    function isValidSchoolRequest(data) {
      return data.keys().hasAll(['requestId', 'schoolName', 'village', 'requestedBy', 'status', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.requestId is string && data.requestId.size() <= 128 &&
             data.schoolName is string && data.schoolName.size() >= 3 && data.schoolName.size() <= 100 &&
             data.village is string && data.village.size() <= 100 &&
             data.requestedBy is string && data.requestedBy.size() <= 100 &&
             data.status is string && data.status == 'pending' &&
             data.createdAt == request.time;
    }

    function isValidVillageRequest(data) {
      return data.keys().hasAll(['requestId', 'villageName', 'requestedBy', 'status', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.requestId is string && data.requestId.size() <= 128 &&
             data.villageName is string && data.villageName.size() >= 3 && data.villageName.size() <= 100 &&
             data.requestedBy is string && data.requestedBy.size() <= 100 &&
             data.status is string && data.status == 'pending' &&
             data.createdAt == request.time;
    }

    function isValidAppConfig(data) {
      return data.keys().hasAll(['latestVersion', 'mandatory', 'apkUrl', 'releaseNotes', 'updatedAt']) &&
             data.keys().size() == 5 &&
             data.latestVersion is string && data.latestVersion.size() <= 20 &&
             data.mandatory is bool &&
             data.apkUrl is string && data.apkUrl.size() <= 1000 &&
             data.releaseNotes is string && data.releaseNotes.size() <= 5000 &&
             data.updatedAt == request.time;
    }

    // ----------------------------------------------------
    // 1. Users Profile Collection (Fully Hardened - ISO-Isolated)
    // ----------------------------------------------------
    match /users/{userId} {
      // Students can ONLY read their own profile. Admins and Super Admins can browse all user profiles.
      allow get: if isCurrentUser(userId) || isAdmin() || isSuperAdmin();
      
      // Block unrestricted listing. Only admin/super_admin can list all users.
      // Unauthenticated requests must be limited (limit <= 100) to prevent bulk database dumps.
      // Logged in students can ONLY query their own profile document.
      allow list: if isAdmin() || isSuperAdmin() ||
                     (!isSignedIn() && request.query.limit != null && request.query.limit <= 100) ||
                     (isSignedIn() && resource.data.uid == request.auth.uid);
      
      // Prevent self-registration elevation of privilege, except for authorized Super Admin bootstrap
      allow create: if (
        isCurrentUser(userId) &&
        isValidUser(incoming()) &&
        incoming().role == 'super_admin' &&
        (request.auth.token.email != null && (request.auth.token.email == 'n.gujarati25288@gmail.com' || request.auth.token.email == '8511125288@daily-learning-exam.com'))
      ) || isAdmin() || isSuperAdmin() || (
        // Standard student self-registration
        isCurrentUser(userId) && 
        isValidUser(incoming()) && 
        incoming().role == 'student' &&
        (!('permissions' in incoming().keys())) &&
        (!('admin' in incoming().keys())) &&
        (!('isAdmin' in incoming().keys()))
      );
        
      // Students can modify their non-identity fields. Admins and Super Admins can update any field.
      // Strict protection of passwordHash, role, status, and permissions. Privilege escalation is blocked.
      allow update: if isAdmin() || isSuperAdmin() || 
                    (
                      isCurrentUser(userId) &&
                      isValidUser(incoming()) &&
                      incoming().role == existing().role &&
                      incoming().status == existing().status &&
                      (!('permissions' in incoming().keys()) || (incoming().permissions == existing().permissions)) &&
                      (!('admin' in incoming().keys()) || (incoming().admin == existing().admin)) &&
                      (!('isAdmin' in incoming().keys()) || (incoming().isAdmin == existing().isAdmin)) &&
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'fullName', 'mobile', 'school', 'standard', 'division', 'village', 'fcmToken', 'lastTokenUpdate', 'passwordHash', 'updatedAt', 'streak', 'lastActiveDate'
                      ])
                    );
      
      allow delete: if isSuperAdmin();
    }

    // ----------------------------------------------------
    // 2. Syllabus Category Systems (Read: Approved, Write: Admin)
    // ----------------------------------------------------
    match /subjects/{subjectId} {
      allow read: if isApproved();
      allow write: if isAdmin() || isSuperAdmin();
    }

    match /chapters/{chapterId} {
      allow read: if isApproved();
      allow write: if isAdmin() || isSuperAdmin();
    }

    // ----------------------------------------------------
    // 3. Question Bank (Read Protected - Student Cannot Scrape ALL)
    // ----------------------------------------------------
    match /questions/{questionId} {
      // Super Admin: Read all questions
      // Admin: Read ONLY own questions
      // Students: Cannot browse/query/edit (no read or write access)
      allow get, list: if isApproved() && (
        isSuperAdmin() || 
        (isAdmin() && resource.data.ownerAdminId == request.auth.uid)
      );

      allow create: if isSuperAdmin() || (
        isAdmin() && 
        incoming().ownerAdminId == request.auth.uid
      );

      allow update: if isSuperAdmin() || (
        isAdmin() && 
        existing().ownerAdminId == request.auth.uid && 
        incoming().ownerAdminId == request.auth.uid
      );

      allow delete: if isSuperAdmin() || (
        isAdmin() && 
        existing().ownerAdminId == request.auth.uid
      );
    }

    // ----------------------------------------------------
    // 4. Exams & Templates Configurations (Read: Approved, Write: Admin)
    // ----------------------------------------------------
    match /daily_exams/{examId} {
      // Super Admin: Full access
      // Admin: Only own exams
      // Students: Read-only access to take exams
      allow get, list: if isApproved() && (
        isSuperAdmin() ||
        (isAdmin() && resource.data.createdByAdminId == request.auth.uid) ||
        (!isAdmin() && !isSuperAdmin())
      );

      allow create: if isSuperAdmin() || (
        isAdmin() && 
        incoming().createdByAdminId == request.auth.uid
      );

      allow update: if isSuperAdmin() || (
        isAdmin() && 
        existing().createdByAdminId == request.auth.uid && 
        incoming().createdByAdminId == request.auth.uid
      );

      allow delete: if isSuperAdmin() || (
        isAdmin() && 
        existing().createdByAdminId == request.auth.uid
      );
    }

    match /exam_templates/{templateId} {
      allow read: if isApproved();
      allow write: if isAdmin() || isSuperAdmin();
    }

    match /scheduled_exams/{examId} {
      // Super Admin: Full access
      // Admin: Only own scheduled exams
      // Students: Read-only access
      allow get, list: if isApproved() && (
        isSuperAdmin() ||
        (isAdmin() && resource.data.createdByAdminId == request.auth.uid) ||
        (!isAdmin() && !isSuperAdmin())
      );

      allow create: if isSuperAdmin() || (
        isAdmin() && 
        incoming().createdByAdminId == request.auth.uid
      );

      allow update: if isSuperAdmin() || (
        isAdmin() && 
        existing().createdByAdminId == request.auth.uid && 
        incoming().createdByAdminId == request.auth.uid
      );

      allow delete: if isSuperAdmin() || (
        isAdmin() && 
        existing().createdByAdminId == request.auth.uid
      );
    }

    match /announcements/{announcementId} {
      allow read: if isApproved();
      allow write: if isAdmin() || isSuperAdmin();
    }

    match /system_config/{configId} {
      allow read: if isApproved();
      allow write: if isAdmin() || isSuperAdmin();
    }

    // ----------------------------------------------------
    // 5. Exam Results, Revision, & Mistake Systems (Students Own Theirs)
    // ----------------------------------------------------
    match /exam_results/{resultId} {
      allow read: if isApproved() && (
        resource == null ||
        resource.data.studentId == request.auth.uid || 
        isAdmin() || 
        isSuperAdmin()
      );

      allow create: if isApproved() && 
                    incoming().studentId == request.auth.uid && 
                    incoming().submittedAt == request.time;

      allow update, delete: if isAdmin() || isSuperAdmin();
    }

    match /student_failures/{failureId} {
      allow read: if isApproved() && (
        resource == null ||
        resource.data.studentId == request.auth.uid || 
        isAdmin() || 
        isSuperAdmin()
      );

      allow create, update: if isApproved() && 
                            incoming().studentId == request.auth.uid;

      allow delete: if isAdmin() || isSuperAdmin();
    }

    match /student_mistakes/{mistakeId} {
      allow read: if isApproved() && (
        resource == null ||
        resource.data.studentId == request.auth.uid || 
        isAdmin() || 
        isSuperAdmin()
      );

      allow create: if isApproved() && 
                    incoming().studentId == request.auth.uid && 
                    incoming().createdAt == request.time;

      allow update: if isApproved() && (
        (existing().studentId == request.auth.uid && 
         incoming().studentId == request.auth.uid &&
         incoming().diff(existing()).affectedKeys().hasOnly([
           'revisionCount', 'correctRevisionCount', 'mastered', 'nextRevisionDate', 
           'lastRevisionDate', 'lastRevisedAt', 'consecutiveCorrectCount', 'revisionLevel', 'masteredAt', 'updatedAt'
         ]) &&
         incoming().updatedAt == request.time) ||
        isAdmin() ||
        isSuperAdmin()
      );

      allow delete: if isAdmin() || isSuperAdmin();
    }

    match /revision_progress/{progressId} {
      allow read: if isApproved() && (
        resource == null ||
        resource.data.studentId == request.auth.uid || 
        isAdmin() || 
        isSuperAdmin()
      );

      allow create: if isApproved() && 
                    incoming().studentId == request.auth.uid && 
                    incoming().lastRevisedAt == request.time;

      allow update: if isApproved() && (
        (existing().studentId == request.auth.uid && 
         incoming().studentId == request.auth.uid &&
         incoming().diff(existing()).affectedKeys().hasOnly([
           'revisionCount', 'correctRevisionCount', 'mastered', 'lastRevisedAt'
         ]) &&
         incoming().lastRevisedAt == request.time) || 
        isAdmin() || 
        isSuperAdmin()
      );

      allow delete: if isAdmin() || isSuperAdmin();
    }

    match /revision_analytics/{studentId} {
      allow read: if isApproved() && (
        studentId == request.auth.uid || 
        isAdmin() || 
        isSuperAdmin()
      );

      allow create: if isApproved() && 
                    studentId == request.auth.uid && 
                    incoming().updatedAt == request.time;

      allow update: if isApproved() && (
        (studentId == request.auth.uid && 
         incoming().updatedAt == request.time &&
         incoming().diff(existing()).affectedKeys().hasOnly([
           'totalRevisions', 'totalCorrectRevisions', 'revisionAccuracy', 
           'strongestSubject', 'weakestSubject', 'pendingRevisionCount', 'masteredQuestionsCount', 'updatedAt'
         ])) || 
        isAdmin() || 
        isSuperAdmin()
      );

      allow delete: if isSuperAdmin();
    }

    match /student_points/{studentId} {
      allow read: if isApproved() && (
        studentId == request.auth.uid || 
        isAdmin() || 
        isSuperAdmin()
      );

      allow create: if isApproved() && 
                    studentId == request.auth.uid && 
                    incoming().updatedAt == request.time;

      allow update: if isApproved() && (
        (studentId == request.auth.uid && 
         incoming().updatedAt == request.time &&
         incoming().diff(existing()).affectedKeys().hasOnly([
           'totalPoints', 'examPoints', 'revisionPoints', 'masteryPoints', 'achievementPoints', 'studentName', 'studentId', 'updatedAt'
         ])) || 
        isAdmin() || 
        isSuperAdmin()
      );

      allow delete: if isSuperAdmin();
    }

    match /achievements/{achievementId} {
      allow read: if isApproved();
      allow create: if isApproved() && 
                    incoming().studentId == request.auth.uid && 
                    incoming().unlockedAt == request.time;
      allow update: if isApproved() && (
                    (existing().studentId == request.auth.uid && 
                     incoming().studentId == request.auth.uid) ||
                    isAdmin() ||
                    isSuperAdmin()
      );
      allow delete: if isAdmin() || isSuperAdmin();
    }

    match /user_achievements/{achievementId} {
      allow read: if isApproved();

      allow create: if isApproved() && 
                    incoming().studentId == request.auth.uid && 
                    incoming().unlockedAt == request.time;

      allow update: if isApproved() && (
                    (existing().studentId == request.auth.uid && 
                     incoming().studentId == request.auth.uid) ||
                    isAdmin() ||
                    isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // ----------------------------------------------------
    // 6. Leaderboard Systems (Direct Dashboard Fast Reads)
    // ----------------------------------------------------
    match /leaderboard/{id} {
      allow read: if isApproved();
      allow create: if isApproved() && (
                    id == request.auth.uid &&
                    incoming().studentId == request.auth.uid
      ) || isAdmin() || isSuperAdmin();
      allow update: if isApproved() && (
                    (id == request.auth.uid && 
                     incoming().diff(existing()).affectedKeys().hasOnly([
                       'studentId', 'studentName', 'totalMarks', 'percentage', 'rank', 'updatedAt'
                     ])) ||
                    isAdmin() ||
                    isSuperAdmin()
      );
      allow delete: if isAdmin() || isSuperAdmin();
    }

    match /leaderboard_daily/{id} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /leaderboard_weekly/{id} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /leaderboard_monthly/{id} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /leaderboard_alltime/{id} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /subject_leaderboards/{id} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /topPerformers/{id} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    // ----------------------------------------------------
    // 7. Academic Analytics & Performance Reports (Admin Only)
    // ----------------------------------------------------
    match /student_analytics/{studentId} {
      allow read: if isApproved() && (
        studentId == request.auth.uid || 
        isAdmin() || 
        isSuperAdmin()
      );
      allow write: if isAdmin() || isSuperAdmin();
    }

    match /subject_analytics/{id} {
      allow read, write: if isAdmin() || isSuperAdmin();
    }

    match /chapter_analytics/{id} {
      allow read, write: if isAdmin() || isSuperAdmin();
    }

    match /question_analytics/{id} {
      allow read, write: if isAdmin() || isSuperAdmin();
    }

    match /school_analytics/{id} {
      allow read, write: if isAdmin() || isSuperAdmin();
    }

    match /village_analytics/{id} {
      allow read, write: if isAdmin() || isSuperAdmin();
    }

    match /standard_analytics/{id} {
      allow read, write: if isAdmin() || isSuperAdmin();
    }

    match /learning_trends/{id} {
      allow read, write: if isAdmin() || isSuperAdmin();
    }

    match /analytics_reports/{id} {
      allow read, write: if isAdmin() || isSuperAdmin();
    }

    // ----------------------------------------------------
    // 8. Master Secondary Data Directories & Requests
    // ----------------------------------------------------
    match /schools/{schoolId} {
      // Public autocomplete reads during registration flow
      allow read: if true;
      allow write: if isAdmin() || isSuperAdmin();
    }

    match /villages/{villageId} {
      // Public autocomplete reads during registration flow
      allow read: if true;
      allow write: if isAdmin() || isSuperAdmin();
    }

    match /school_requests/{requestId} {
      allow read: if isAdmin() || isSuperAdmin();
      allow create: if isValidId(requestId) && isValidSchoolRequest(incoming());
      allow update, delete: if isAdmin() || isSuperAdmin();
    }

    match /village_requests/{requestId} {
      allow read: if isAdmin() || isSuperAdmin();
      allow create: if isValidId(requestId) && isValidVillageRequest(incoming());
      allow update, delete: if isAdmin() || isSuperAdmin();
    }

    // ----------------------------------------------------
    // 9. Diagnostics, Audit Logs, Scheduler History (Privileged)
    // ----------------------------------------------------
    match /admin_audit_logs/{id} {
      allow read: if isAdmin() || isSuperAdmin();
      allow write: if isApproved();
    }

    match /leaderboard_audit_logs/{id} {
      allow read: if isAdmin() || isSuperAdmin();
      allow write: if isApproved();
    }

    match /security_logs/{id} {
      allow read, write: if isSuperAdmin();
    }

    match /system_backups/{id} {
      allow read, write: if isSuperAdmin();
    }

    match /notifications/{id} {
      allow read: if isApproved() && (
        resource == null ||
        resource.data.studentId == request.auth.uid || 
        isAdmin() || 
        isSuperAdmin()
      );
      allow write: if isAdmin() || isSuperAdmin();
    }

    match /notification_history/{recordId} {
      allow read: if isApproved() && (
        resource == null ||
        resource.data.studentId == request.auth.uid || 
        isAdmin() || 
        isSuperAdmin()
      );

      allow create: if isApproved() && (
        incoming().studentId == request.auth.uid || 
        isAdmin() || 
        isSuperAdmin()
      );

      allow update: if isApproved() && (
        (incoming().studentId == request.auth.uid &&
         incoming().diff(existing()).affectedKeys().hasOnly(['opened']) &&
         existing().studentId == request.auth.uid) ||
        isAdmin() ||
         isSuperAdmin()
      );

      allow delete: if isAdmin() || isSuperAdmin();
    }

    // ----------------------------------------------------
    // 10. App Config/Settings (Read: Public, Write: Super Admin)
    // ----------------------------------------------------
    match /app_config/{configId} {
      allow read: if true;
      allow create, update: if isSuperAdmin() && isValidId(configId) && isValidAppConfig(incoming());
      allow delete: if isSuperAdmin();
    }
  }
}
