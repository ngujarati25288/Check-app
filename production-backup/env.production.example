# =========================================================================
# DAILY LEARNING EXAM - PRODUCTION ENVIRONMENT CONFIGURATION BACKUP
# =========================================================================
# This file serves as a reference backup for setting up the production環境
# on a secure cloud server, App Engine, Cloud Run, or custom host machine.
# Duplicate this file into '.env.production' and fill in active keys securely.
# DO NOT commit real secrets or service credentials into codebase repositories.

# 1. CORE SUITE IDENTIFICATION
# ─────────────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=3000
HOST="0.0.0.0"

# 2. FIREBASE / GOOGLE CLOUD SUITE API KEYS (CLIENT ENVIRONMENT)
# ─────────────────────────────────────────────────────────────────────────
# Obtain these credentials from Firebase Console -> Project Settings -> General -> Web Apps
VITE_FIREBASE_API_KEY="AIzaSyA1..."
VITE_FIREBASE_AUTH_DOMAIN="daily-learning-exam-prod.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="daily-learning-exam-prod"
VITE_FIREBASE_STORAGE_BUCKET="daily-learning-exam-prod.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="3620..."
VITE_FIREBASE_APP_ID="1:3620:web:d26d..."

# FCM Web Push Certificate (VAPID key)
# Obtain from Cloud Messaging tab -> Web configuration -> Web Push certificates
VITE_FIREBASE_VAPID_PUBLIC_KEY="BIdlB9..."

# 3. BACKEND EXAMINER & GEMINI CORES (SERVER SECRETS ONLY)
# ─────────────────────────────────────────────────────────────────────────
# Gemini API Key: Required for administrative question generation, exam synthesis & automated reports
# IMPORTANT: Never prefix with VITE_ or expose to client bundles.
GEMINI_API_KEY="AIzaSyDco..."

# Web Access / Frontend Host Endpoint (used in links, email redirects, and notification deep links)
APP_URL="https://daily-learning-exam-prod-run.app"

# 4. SERVER SYSTEM BACKUPS & GCS STORAGE HOOKS
# ─────────────────────────────────────────────────────────────────────────
# Target storage bucket where daily Firestore snapshot exports are archived
GCP_BACKUP_STORAGE_BUCKET="gs://dle-production-backups-bucket-asia"

# Google Application Credentials (JSON key filepath for administrative operations)
# Automatically fetched by GCS client on Cloud Run. For local backup runs, set absolute path.
GOOGLE_APPLICATION_CREDENTIALS="/secrets/firebase-admin-service-account.json"

# 5. SECURITY & REGULATORY HEADERS
# ─────────────────────────────────────────────────────────────────────────
# Prevent clickjacking and force secure protocol layers
SECURE_REFERRER_POLICY="no-referrer"
ENABLE_APP_CHECK_ENFORCEMENT="true"
RECAPTCHA_ENTERPRISE_SITE_KEY="6Ld8..."
