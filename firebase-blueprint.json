          "type": "string",
          "description": "The standard of this question"
        },
        "questionType": {
          "type": "string",
          "enum": ["MCQ", "TrueFalse", "FillBlank", "MatchFollowing"],
          "description": "Type of the question"
        },
        "options": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Options array for MCQ and dynamic question types"
        },
        "marks": {
          "type": "integer",
