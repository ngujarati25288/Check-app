          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "ownerAdminId": {
          "type": "string",
          "description": "UID of the admin who owns this question"
        },
        "ownerAdminName": {
          "type": "string",
          "description": "Full name of the admin who owns this question"
        }
      },
