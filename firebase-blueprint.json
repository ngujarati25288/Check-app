{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account details representing students, admins, and super admins",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique identifier of the user matching Firebase Auth UID"
        },
        "fullName": {
          "type": "string",
          "description": "Student's full name"
        },
        "mobile": {
          "type": "string",
          "description": "Unique mobile number format"
        },
        "school": {
          "type": "string",
          "description": "School name"
        },
        "standard": {
          "type": "string",
          "description": "Standard of class (e.g., '7', '8', '9', '10')"
        },
        "village": {
          "type": "string",
          "description": "Village or city of residence"
        },
        "role": {
          "type": "string",
          "enum": ["student", "admin", "super_admin"],
          "description": "Functional role within database"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "blocked"],
          "description": "Approval status for database access"
        },
        "fcmToken": {
          "type": "string",
          "description": "FCM cloud registration token for alerts"
        },
        "lastTokenUpdate": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the client token was refreshed"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Server timestamp of creation"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Server timestamp of final edit"
        }
      },
      "required": ["uid", "fullName", "mobile", "role", "status", "createdAt"]
    },
